---
interface Props {
  src: string;
  title?: string;
}
const { src, title = "Resume" } = Astro.props as Props;
---
<div class="overflow-hidden rounded-2xl border border-slate-200 shadow-soft dark:border-slate-700">
  <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50 px-4 py-2.5 dark:border-slate-700 dark:bg-slate-800/60">
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      {title}
    </span>
    
      href={src}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-semibold text-gold-700 hover:underline dark:text-gold-300"
    >
      Open in new tab &rarr;
    </a>
  </div>

  <object data={src} type="application/pdf" class="h-[70vh] w-full sm:h-[85vh]">
    <div class="flex h-[50vh] flex-col items-center justify-center gap-3 bg-slate-50 p-6 text-center dark:bg-slate-800/40">
      <p class="text-sm text-slate-600 dark:text-slate-400">
        Your browser can't display the embedded PDF.
      </p>
      <a href={src} target="_blank" rel="noopener noreferrer" class="btn-secondary">
        Open Resume in New Tab
      </a>
    </div>
  </object>
</div>
