---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResumeEmbed from "../components/ResumeEmbed.astro";
import personal from "../data/personal.json";
---
<BaseLayout title="Resume" description={`Resume for ${personal.fullName}.`}>

  <section class="container-page pb-8 pt-14 sm:pt-20">
    <div class="mx-auto max-w-3xl resume-doc text-center">
      <p class="eyebrow mb-3 font-sans">Curriculum Vitae</p>
      <h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">{personal.fullName}</h1>
      <p class="mt-3 font-serif text-lg italic text-slate-600 dark:text-slate-400">{personal.professionalTitle}</p>
      <p class="mt-4 font-sans text-sm text-slate-500 dark:text-slate-400">
        {personal.email} &nbsp;&middot;&nbsp; {personal.phone} &nbsp;&middot;&nbsp; {personal.location}
      </p>
      <div class="mx-auto mt-6 h-px w-24 bg-slate-300 dark:bg-slate-600"></div>
    </div>
  </section>

  <section class="container-page pb-6 no-print">
    <div class="mx-auto flex max-w-3xl flex-wrap justify-center gap-3">
      <a href={personal.resumeFile} class="btn-primary" download>Download Resume (PDF)</a>
      <button
        type="button"
        onclick="window.print()"
        class="btn-secondary"
      >
        Print / Save as PDF
      </button>
    </div>
  </section>

  <section class="container-page pb-10 no-print">
    <div class="mx-auto max-w-3xl">
      <ResumeEmbed src={personal.resumeFile} title={personal.fullName} />
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="mx-auto max-w-3xl resume-doc space-y-12">

      <div>
        <h2>Experience</h2>
        <div class="space-y-8">
          {personal.experience.map((exp) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <p class="entry-title">{exp.role}</p>
                <p class="entry-meta">{exp.period}</p>
              </div>
              <p class="entry-org">{exp.company}</p>
              <ul class="mt-2 list-disc space-y-1.5 pl-5 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                {exp.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2>Teaching Experience</h2>
        <div class="space-y-8">
          {personal.teachingExperience.map((t) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <p class="entry-title">{t.role}</p>
                <p class="entry-meta">{t.period}</p>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300">{t.details}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2>Education</h2>
        <div class="space-y-6">
          {personal.education.map((ed) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <p class="entry-title">{ed.degree}</p>
                <p class="entry-meta">{ed.period}</p>
              </div>
              <p class="entry-org">{ed.institution}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2>Honors &amp; Awards</h2>
        <ul class="space-y-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
          {personal.awards.map((a) => (
            <li class="flex flex-wrap justify-between gap-x-4">
              <span>{a.title} <span class="entry-meta font-normal normal-case tracking-normal text-slate-500 dark:text-slate-400">&mdash; {a.result}</span></span>
              <span class="entry-meta">{a.year}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="grid gap-10 sm:grid-cols-2">
        <div>
          <h2>Languages</h2>
          <ul class="space-y-1.5 text-sm text-slate-700 dark:text-slate-300">
            {personal.languages.map((l) => (
              <li class="flex justify-between">
                <span>{l.name}</span>
                <span class="text-slate-500 dark:text-slate-400">{l.level}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2>Skills</h2>
          <div class="space-y-3 text-sm text-slate-700 dark:text-slate-300">
            <p><span class="entry-meta">Finance &amp; Accounting</span><br />{personal.skills.financeAndAccounting.join(", ")}</p>
            <p><span class="entry-meta">Procurement &amp; Operations</span><br />{personal.skills.procurementAndOperations.join(", ")}</p>
            <p><span class="entry-meta">IT &amp; Data Tools</span><br />{personal.skills.itAndDataTools.join(", ")}</p>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
