---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
}
const { title = "Siratee Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Your Umami Tracking Script -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="YOUR-UNIQUE-ID"></script>

    <!-- The View Transitions Component -->
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>
